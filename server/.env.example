# ╔════════════════════════════════════════════════════════════════╗
# ║  Eleganza · Backend Environment Template                        ║
# ║  Copy to .env and fill in real values.                          ║
# ╚════════════════════════════════════════════════════════════════╝

# ─── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.55
OPENAI_MAX_TOKENS=600

# ─── Server ────────────────────────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Conversation memory (in-process for now) ──────────────────────
MAX_HISTORY_TURNS=16
SESSION_TTL_MINUTES=180

# ─── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
